{
  "permissions": {
    "defaultMode": "auto",
    "allow": [
      "Bash(git:*)",
      "Bash(grep:*)",
      "Bash(tail:*)",
      "Bash(head:*)",
      "Bash(awk:*)",
      "Bash(sed:*)",
      "Bash(wc:*)",
      "Bash(cat:*)",
      "Bash(ls:*)",
      "Bash(find:*)",
      "Bash(echo:*)",
      "Bash(cd:*)",
      "Bash(seq:*)",
      "Bash(pgrep:*)",
      "Bash(test:*)",
      "Bash(scripts/*.sh:*)",
      "Bash(uv:*)",
      "Bash(.worktrees/*/runs/staging/.venv/bin/python:*)",
      "Bash(runs/*/*/base-venv/bin/python:*)",
      "Bash(timeout:*)",
      "Bash(mkdir:*)",
      "Bash(rmdir:*)",
      "Bash(rm:*)",
      "Bash(mv:*)",
      "Bash(cp:*)",
      "Bash(cp -r:*)",
      "Bash(ln:*)",
      "Bash(ln -s:*)",
      "Bash(CUDA_VISIBLE_DEVICES=*:*)",
      "Bash(wait:*)",
      "Bash(jobs:*)",
      "Bash(kill:*)",
      "Bash(nvidia-smi:*)",
      "Bash(tail -F:*)",
      "Bash(tail -f:*)",
      "Read(*)",
      "Edit(.worktrees/**)",
      "Write(.worktrees/**)",
      "Edit(tasks/**)",
      "Write(tasks/**)",
      "Edit(.slots/**)",
      "Write(.slots/**)",
      "Agent(*)",
      "WebSearch",
      "WebFetch"
    ],
    "deny": [
      "Edit(evaluate.py)",
      "Write(evaluate.py)",
      "Edit(prepare.py)",
      "Write(prepare.py)",
      "Edit(requirements.txt)",
      "Write(requirements.txt)",
      "Edit(program.md)",
      "Write(program.md)",
      "Edit(contract.md)",
      "Write(contract.md)",
      "Edit(scripts/**)",
      "Write(scripts/**)",
      "Edit(.claude/**)",
      "Write(.claude/**)",
      "Edit(toolkit/**)",
      "Write(toolkit/**)",
      "Edit(examples/**)",
      "Write(examples/**)",
      "Edit(data/**)",
      "Write(data/**)",
      "Bash(git push:*)",
      "Bash(git push --force:*)",
      "Bash(git push --force-with-lease:*)",
      "Bash(git push -f:*)"
    ],
    "additionalDirectories": []
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "compact",
        "hooks": [
          {
            "type": "command",
            "command": "cat \"$CLAUDE_PROJECT_DIR\"/program.md"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Edit|Write|NotebookEdit|MultiEdit|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/guard.py"
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "mkdir -p \"$CLAUDE_PROJECT_DIR\"/.slots && printf 'subagent_stop %s\\n' \"$(date +%s)\" >> \"$CLAUDE_PROJECT_DIR\"/.slots/events.log"
          }
        ]
      }
    ]
  },
  "_comment": "Autonomous campaign integrity is enforced by .claude/hooks/guard.py. Candidate agents edit only .worktrees/**/candidate.py and runtime files. Root tasks/** is writable for initialization; task packs inside worktrees plus harness, examples, toolkit, and data are read-only."
}
